model OnboardingFlow {
  id          String   @id @default(cuid())
  key         String   @unique @db.VarChar(100)
  title       String   @db.VarChar(200)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps           OnboardingStep[]
  planAccess      OnboardingFlowPlan[]
  tenantOverrides OnboardingFlowTenant[]
  completions     UserOnboardingCompletion[]

  @@map("onboarding_flows")
}

model OnboardingStep {
  id          String   @id @default(cuid())
  flowId      String
  title       String   @db.VarChar(200)
  description String?  @db.Text
  target      String   @db.VarChar(300)
  placement   String   @default("bottom") @db.VarChar(20)
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  flow OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([flowId])
  @@map("onboarding_steps")
}

// Sin filas = acceso para todos los planes. Con filas = solo esos planes.
model OnboardingFlowPlan {
  flowId String
  planId String

  flow OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  plan Plan           @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([flowId, planId])
  @@map("onboarding_flow_plans")
}

// Override por tenant: isEnabled=false bloquea, isEnabled=true fuerza (gana sobre plan)
model OnboardingFlowTenant {
  flowId    String
  tenantId  String
  isEnabled Boolean @default(true)

  flow   OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([flowId, tenantId])
  @@map("onboarding_flow_tenants")
}

// Un registro = usuario completó ese flow para siempre
model UserOnboardingCompletion {
  userId      String
  flowId      String
  completedAt DateTime @default(now())

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  flow OnboardingFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@id([userId, flowId])
  @@index([userId])
  @@map("user_onboarding_completions")
}
