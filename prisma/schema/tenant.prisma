model Plan {
  id                String       @id @default(cuid())
  name              String       @db.VarChar(100)
  slug              String       @unique @db.VarChar(50)
  description       String?      @db.Text
  price             Decimal      @db.Decimal(10, 2)
  interval          PlanInterval @default(MONTHLY)
  maxUsers          Int          @default(5)
  maxOrdersPerMonth Int          @default(500)
  stripePriceId     String?      @db.VarChar(255)
  features          Json         @default("[]")
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenants           Tenant[]
  invoices          Invoice[]
  scheduledFromPlan ScheduledPlanChange[] @relation("FromPlan")
  scheduledToPlan   ScheduledPlanChange[] @relation("ToPlan")
  onboardingFlows   OnboardingFlowPlan[]

  @@map("plans")
}

model Tenant {
  id                   String    @id @default(cuid())
  name                 String    @db.VarChar(200)
  slug                 String    @unique @db.VarChar(100)
  domain               String?   @unique @db.VarChar(255)
  logoUrl              String?   @db.Text
  phone                String?   @db.VarChar(20)
  email                String?   @db.VarChar(255)
  address              String?   @db.Text
  stripeCustomerId     String?   @db.VarChar(255)
  stripeSubscriptionId String?   @db.VarChar(255)
  planId               String?
  trialEndsAt          DateTime?
  isActive             Boolean   @default(true)
  commissionRate       Decimal   @default(0) @db.Decimal(5, 2)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  plan                 Plan?                 @relation(fields: [planId], references: [id])
  tenantUsers          TenantUser[]
  invitations          Invitation[]
  clients              Client[]
  vehicles             Vehicle[]
  clientVehicles       ClientVehicle[]
  serviceTypes         ServiceType[]
  serviceOrders        ServiceOrder[]
  invoices             Invoice[]
  payments             Payment[]
  scheduledPlanChanges ScheduledPlanChange[]
  paymentReminders     PaymentReminder[]
  onboardingOverrides  OnboardingFlowTenant[]
  washerEarnings       WasherEarning[]
  washerPayouts        WasherPayout[]

  @@index([slug])
  @@index([planId])
  @@map("tenants")
}

model TenantUser {
  id        String     @id @default(cuid())
  userId    String
  tenantId  String
  role      TenantRole @default(EMPLOYEE)
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@map("tenant_users")
}

model Invitation {
  id          String     @id @default(cuid())
  email       String     @db.VarChar(255)
  tenantId    String
  role        TenantRole @default(EMPLOYEE)
  token       String     @unique
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String
  createdAt   DateTime   @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invitedBy User   @relation("InvitedByUser", fields: [invitedById], references: [id])

  @@index([token])
  @@index([tenantId])
  @@index([invitedById])
  @@map("invitations")
}
